{{ 'lab-ai-advisor.css' | asset_url | stylesheet_tag }}

<div id="lab-ai-advisor-root" 
  data-store="{{ shop.permanent_domain }}"
  data-currency="{{ cart.currency.iso_code }}"
  data-gemini-key="{{ block.settings.gemini_api_key }}">
</div>

{{ 'lab-ai-advisor.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "LAB AI Advisor",
  "target": "body",
  "javascript": "lab-ai-advisor.js",
  "stylesheet": "lab-ai-advisor.css",
  "settings": [
    {
      "type": "text",
      "id": "gemini_api_key",
      "label": "Google Gemini API Key",
      "info": "Ingresa tu API key de Google Gemini (AI Studio) aquí"
    },
    {
      "type": "checkbox",
      "id": "show_whatsapp",
      "label": "Mostrar botón compartir por WhatsApp",
      "default": true
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Número WhatsApp (con código país)",
      "placeholder": "51999999999"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color principal del widget",
      "default": "#00ff88"
    }
  ]
}
{% endschema %}
