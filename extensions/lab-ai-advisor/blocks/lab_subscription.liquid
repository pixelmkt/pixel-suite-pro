{{ 'lab-sub.css' | asset_url | stylesheet_tag }}
<style>
  #lab-sub-{{ block.id }} {
    --lab-bg: {{ block.settings.color_bg | default: '#ffffff' }};
    --lab-benefit-bg: {{ block.settings.color_benefit | default: 'rgba(157, 42, 35, 0.05)' }};
    --lab-tab-bg: {{ block.settings.color_tab_bg | default: '#f9fafb' }};
    --lab-tab-act: {{ block.settings.color_tab_act | default: '#ffffff' }};
    --lab-tab-text: {{ block.settings.color_tab_text | default: '#6b7280' }};
    --lab-tab-act-text: {{ block.settings.color_tab_act_text | default: '#9d2a23' }};
    --lab-tab-size: {{ block.settings.font_size_tabs | default: 13 }}px;
    --lab-gift-bg-from: {{ block.settings.gift_bg_from | default: '#fff8e1' }};
    --lab-gift-bg-to: {{ block.settings.gift_bg_to | default: '#fff1c7' }};
    --lab-gift-border: {{ block.settings.gift_border | default: '#f2c94c' }};
    --lab-gift-badge-bg: {{ block.settings.gift_badge_bg | default: '#E30613' }};
    --lab-gift-badge-text: {{ block.settings.gift_badge_text | default: '#ffffff' }};
    --lab-gift-title: {{ block.settings.gift_title_color | default: '#4A3100' }};
    --lab-gift-label: {{ block.settings.gift_label_color | default: '#8B6914' }};
  }
  /* Ocultar selector nativo de selling plans del tema — usamos nuestro widget */
  .product-form__input--selling-plan,
  .shopify-payment-terms,
  fieldset[data-type="selling-plan-select"],
  .selling-plan-group-option,
  .product-form__selling-plan-fieldset,
  purchase-options-radio-component,
  .purchase-options-radio { display: none !important; }
</style>

{%- liquid
  assign variant      = product.selected_or_first_available_variant
  assign sale_price   = variant.price
  assign compare_price = variant.compare_at_price | default: 0
  assign sale_float   = sale_price | divided_by: 100.0
  assign compare_float = compare_price | divided_by: 100.0
  assign has_compare  = false
  if compare_price > sale_price and compare_price > 0
    assign has_compare = true
    assign save_pct = compare_price | minus: sale_price | times: 100 | divided_by: compare_price
  endif
  assign currency     = cart.currency.iso_code | default: 'PEN'
  assign btn_once     = block.settings.text_btn_once | default: 'Compra única'
  assign btn_sub      = block.settings.text_btn_sub  | default: 'Suscripción'
  assign badge_txt    = block.settings.badge_text    | default: 'HASTA -30%'
  assign primary      = block.settings.primary_color | default: '#9d2a23'
  assign backend_url  = block.settings.backend_url   | default: 'https://pixel-suite-pro-production.up.railway.app'
  assign free_ship    = block.settings.free_shipping | default: false
  assign legal_txt    = block.settings.text_legal    | default: 'Cancelación disponible entre los días 30 y 15 antes de cada envío, una vez completada la permanencia.'
  assign has_plans    = false
  # NOTE: has_plans is intentionally FALSE — MP does not support Shopify native selling plans (deferred_payment_authorization). Always use MP PreApproval flow.
-%}

<div class="lab-sub"
  id="lab-sub-{{ block.id }}"
  data-variant="{{ variant.id }}"
  data-product="{{ product.id }}"
  data-price="{{ sale_float }}"
  data-compare="{{ compare_float }}"
  data-currency="{{ currency }}"
  data-cur-symbol="{{ block.settings.currency_sym | escape }}"
  data-p1="{{ block.settings.plan_1_price | escape }}"
  data-p2="{{ block.settings.plan_2_price | escape }}"
  data-p3="{{ block.settings.plan_3_price | escape }}"
  data-p4="{{ block.settings.plan_4_price | escape }}"
  data-title="{{ product.title | escape }}"
  data-handle="{{ product.handle }}"
  data-backend="{{ backend_url }}"
  style="--lab-primary: {{ primary }}"
  {{ block.shopify_attributes }}>

  <!-- MODE TOGGLE -->
  <div class="lab-sub__toggle">
    <button class="lab-sub__tab lab-sub__tab--active" data-tab="once">{{ btn_once }}</button>
    <button class="lab-sub__tab" data-tab="sub">
      <span>{{ btn_sub }}</span>
      {% if block.settings.show_badge %}
      <span class="lab-sub__pill">{{ badge_txt }}</span>
      {% endif %}
    </button>
  </div>

  <!-- ONE-TIME PANEL -->
  <div class="lab-sub__panel lab-sub__panel--active" data-panel="once">
    {% if free_ship %}
    <div class="lab-sub__free-ship">Envío gratis incluido</div>
    {% endif %}
  </div>

  <!-- SUBSCRIPTION PANEL -->
  <div class="lab-sub__panel" data-panel="sub">

    <!-- Variant restriction notice — only shows when non-eligible variant is selected -->
    <div class="lab-sub__variant-notice" id="variant-notice-{{ block.id }}" style="display:none;background:#fffbeb;border:1.5px solid #f59e0b;border-radius:10px;padding:14px 16px;margin-bottom:16px;text-align:center">
      <div style="font-size:13px;font-weight:700;color:#92400e">⚠️ {{ block.settings.variant_notice_text | default: 'Suscripción disponible solo para la presentación de 500g' }}</div>
      <div style="font-size:12px;color:#78716c;margin-top:4px">Selecciona la variante de <strong>500g</strong> para acceder a los planes de suscripción con descuento.</div>
    </div>
    <div id="sub-content-{{ block.id }}">

    {% comment %}Selling plans nativo deshabilitado — usamos MP PreApproval{% endcomment %}
    {% if false %}{% else %}      <!-- Note: actual plans are loaded dynamically from backend via loadConfig() -->
      <div class="lab-sub__group">
        <p class="lab-sub__label">Elige tu plan</p>
        <div class="lab-sub__chips" id="plan-chips-{{ block.id }}">
          <button class="lab-sub__chip lab-sub__chip--active" data-plan-key="m1_p3">Mensual · 3 meses</button>
          <button class="lab-sub__chip" data-plan-key="m1_p6">Mensual · 6 meses</button>
        </div>
      </div>
      <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:12px 14px;margin-bottom:12px;font-size:12px;color:#166534;text-align:center;line-height:1.5">
        <strong>Recibes 1 Creatina Monohidratada 500g cada mes</strong><br>
        <span style="font-size:11px;color:#15803d">Se cobra automáticamente a tu tarjeta cada mes + S/10 de envío</span><br>
        <span style="font-size:10px;color:#16a34a;font-weight:600">Todos los precios incluyen IGV</span>
      </div>

      {% if block.settings.show_benefit_box %}
      <div class="lab-sub__benefit" id="benefit-{{ block.id }}">
        <div class="lab-sub__benefit-top">
          <div class="lab-sub__pct" id="pct-{{ block.id }}">30% OFF</div>
          <div class="lab-sub__prices">
            <span class="lab-sub__was" id="was-{{ block.id }}"></span>
            <span class="lab-sub__now" id="now-{{ block.id }}"></span>
          </div>
        </div>
        <div class="lab-sub__saving" id="saving-{{ block.id }}"></div>
      </div>
      {% endif %}

      {% if block.settings.show_perks %}
      <div class="lab-sub__perks">
        {% if block.settings.perk_1 != blank %}<div class="lab-sub__perk">{{ block.settings.perk_1 | escape }}</div>{% endif %}
        {% if block.settings.perk_2 != blank %}<div class="lab-sub__perk">{{ block.settings.perk_2 | escape }}</div>{% endif %}
        {% if block.settings.perk_3 != blank %}<div class="lab-sub__perk">{{ block.settings.perk_3 | escape }}</div>{% endif %}
        {% if block.settings.perk_4 != blank %}<div class="lab-sub__perk">{{ block.settings.perk_4 | escape }}</div>{% endif %}
      </div>
      {% endif %}

      {% if block.settings.show_legal %}
      <div class="lab-sub__legal">{{ legal_txt }}</div>
      {% endif %}

      <!-- CTA fallback → modal MP -->
      <button class="lab-sub__cta" id="cta-{{ block.id }}" onclick="labSubOpenModal('{{ block.id }}')">
        <span class="lab-sub__cta-text">Suscribirme →</span>
      </button>
      <div id="lab-msg-{{ block.id }}" style="display:none;padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;text-align:center"></div>
    {% endif %}

  </div>{%- comment -%}close #sub-content{%- endcomment -%}
  </div>

  {% if block.settings.show_social %}
  <div class="lab-sub__social" id="social-{{ block.id }}">
    <span class="lab-sub__social-dot"></span>
    <span id="social-text-{{ block.id }}">Cargando...</span>
  </div>
  {% endif %}

  <!-- CHECKOUT MODAL (solo para fallback sin selling plans) -->
  {% unless has_plans %}
  <div id="lab-modal-{{ block.id }}" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:2147483647;align-items:center;justify-content:center;padding:16px">
    <div style="background:#fff;border-radius:12px;width:100%;max-width:460px;max-height:90vh;overflow-y:auto;position:relative">
      <button onclick="document.getElementById('lab-modal-{{ block.id }}').style.display='none'" style="position:absolute;top:14px;right:16px;background:none;border:none;font-size:20px;cursor:pointer;color:#666">×</button>
      <div style="padding:28px">
        <div style="font-size:11px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#9d2a23;margin-bottom:6px">LAB NUTRITION</div>
        <div style="font-size:19px;font-weight:900;margin-bottom:4px" id="modal-title-{{ block.id }}">Suscripción mensual</div>
        <div style="font-size:13px;color:#666;margin-bottom:6px">{{ product.title }} — 500g</div>
        <div style="background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:10px 12px;margin-bottom:14px;font-size:11px;color:#9a3412;line-height:1.5;text-align:center">
          <strong>Cada mes</strong> se cobra automáticamente a tu tarjeta y recibes <strong>1 unidad</strong> de {{ product.title }} 500g en tu dirección. El precio mostrado es <strong>por unidad mensual</strong> + S/10 de envío. <strong>Todos los precios incluyen IGV.</strong>
        </div>
        <div style="background:#f8f8f8;border-radius:8px;padding:14px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:center">
          <div>
            <div style="font-size:11px;color:#888;font-weight:700;text-transform:uppercase;letter-spacing:.8px">Cobro mensual (1 unidad)</div>
            <div style="font-size:22px;font-weight:900;margin-top:2px" id="modal-price-{{ block.id }}"></div>
            <div style="font-size:10px;color:#888;margin-top:2px">+ S/10.00 envío · IGV incluido</div>
          </div>
          <div style="text-align:right">
            <div id="modal-disc-{{ block.id }}" style="background:#9d2a23;color:#fff;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:800"></div>
            <div id="modal-saving-{{ block.id }}" style="font-size:11px;color:#666;margin-top:4px"></div>
          </div>
        </div>
        <div style="display:grid;gap:12px;margin-bottom:20px">
          <div>
            <label style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:#888;display:block;margin-bottom:5px">Nombre completo</label>
            <input id="m-name-{{ block.id }}" type="text" placeholder="Tu nombre completo" style="width:100%;border:1.5px solid #e5e7eb;border-radius:6px;padding:10px 12px;font-size:14px;outline:none;box-sizing:border-box">
          </div>
          <div>
            <label style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:#888;display:block;margin-bottom:5px">Email</label>
            <input id="m-email-{{ block.id }}" type="email" placeholder="tu@email.com" style="width:100%;border:1.5px solid #e5e7eb;border-radius:6px;padding:10px 12px;font-size:14px;outline:none;box-sizing:border-box"
              value="{{ customer.email | default: '' }}">
          </div>
          <div>
            <label style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:#888;display:block;margin-bottom:5px">Teléfono</label>
            <input id="m-phone-{{ block.id }}" type="tel" placeholder="+51 999 999 999" style="width:100%;border:1.5px solid #e5e7eb;border-radius:6px;padding:10px 12px;font-size:14px;outline:none;box-sizing:border-box">
          </div>
          <div style="display:grid;grid-template-columns:auto 1fr;gap:10px">
            <div>
              <label style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:#888;display:block;margin-bottom:5px">Tipo doc.</label>
              <select id="m-tipodoc-{{ block.id }}" style="border:1.5px solid #e5e7eb;border-radius:6px;padding:10px 8px;font-size:14px;outline:none;box-sizing:border-box;background:#fff">
                <option value="01">DNI</option>
                <option value="06">RUC</option>
                <option value="04">CE</option>
              </select>
            </div>
            <div>
              <label style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:#888;display:block;margin-bottom:5px">Nro. documento</label>
              <input id="m-dni-{{ block.id }}" type="text" placeholder="12345678" style="width:100%;border:1.5px solid #e5e7eb;border-radius:6px;padding:10px 12px;font-size:14px;outline:none;box-sizing:border-box">
            </div>
          </div>
          <div style="border-top:1px solid #f0f0f0;padding-top:12px;margin-top:4px">
            <div style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:#9d2a23;margin-bottom:10px">Dirección de envío</div>
          </div>
          <div>
            <label style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:#888;display:block;margin-bottom:5px">Dirección</label>
            <input id="m-addr-{{ block.id }}" type="text" placeholder="Av. ejemplo 123, Dpto 4B" style="width:100%;border:1.5px solid #e5e7eb;border-radius:6px;padding:10px 12px;font-size:14px;outline:none;box-sizing:border-box">
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
            <div>
              <label style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:#888;display:block;margin-bottom:5px">Distrito</label>
              <input id="m-city-{{ block.id }}" type="text" placeholder="Miraflores" style="width:100%;border:1.5px solid #e5e7eb;border-radius:6px;padding:10px 12px;font-size:14px;outline:none;box-sizing:border-box">
            </div>
            <div>
              <label style="font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;color:#888;display:block;margin-bottom:5px">Provincia / Departamento</label>
              <input id="m-province-{{ block.id }}" type="text" placeholder="Lima" value="Lima" style="width:100%;border:1.5px solid #e5e7eb;border-radius:6px;padding:10px 12px;font-size:14px;outline:none;box-sizing:border-box">
            </div>
          </div>
        </div>
        <div id="m-msg-{{ block.id }}" style="display:none;padding:10px 12px;border-radius:6px;font-size:12px;margin-bottom:12px"></div>

        <!-- T&C Section -->
        <div style="margin-bottom:16px">
          <div id="lab-tc-toggle-{{ block.id }}" style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:12px;color:#9d2a23;font-weight:700;margin-bottom:8px;user-select:none" onclick="(function(id){var c=document.getElementById('lab-tc-body-'+id);var a=document.getElementById('lab-tc-arrow-'+id);if(c.style.display==='none'){c.style.display='block';a.textContent='▾'}else{c.style.display='none';a.textContent='▸'}})('{{ block.id }}')">
            <span id="lab-tc-arrow-{{ block.id }}">▸</span>
            <span>Términos y Condiciones de Suscripción</span>
          </div>
          <div id="lab-tc-body-{{ block.id }}" style="display:none;background:#fafafa;border:1px solid #e5e7eb;border-radius:8px;padding:14px 16px;font-size:11px;color:#555;line-height:1.6;max-height:200px;overflow-y:auto">
            {% if block.settings.tc_text != blank and block.settings.tc_text != 'Ver términos completos en labnutrition.pe' %}{{ block.settings.tc_text | newline_to_br }}{% else %}<strong>Términos y Condiciones — Club Black Diamond</strong><br><br>Programa de suscripción mensual con cobro automático vía Mercado Pago. Precios incluyen IGV (Ley 29571). Descuento exclusivo por permanencia (3 o 6 cobros). Cancelación libre tras cumplir permanencia; anticipada aplica reintegro proporcional del descuento recibido. Retracto 7 días si producto no se abrió. Pausa hasta 2 meses. Envío vía Urbaner/courier 1-3 días. Datos protegidos Ley 29733. Contacto: club@labnutrition.pe · Libro de Reclamaciones en labnutrition.pe/reclamaciones.<br><br>Ver términos completos: <a href="/pages/terminos-suscripcion" style="color:#9d2a23">labnutrition.com/pages/terminos-suscripcion</a>{% endif %}
          </div>
          <label style="display:flex;align-items:flex-start;gap:8px;margin-top:10px;cursor:pointer">
            <input type="checkbox" id="lab-tc-check-{{ block.id }}" style="margin-top:2px;accent-color:#9d2a23;width:16px;height:16px;flex-shrink:0">
            <span style="font-size:11px;color:#666;line-height:1.4">He leído y acepto los <span style="color:#9d2a23;font-weight:700;cursor:pointer;text-decoration:underline" onclick="event.preventDefault();(function(id){var c=document.getElementById('lab-tc-body-'+id);var a=document.getElementById('lab-tc-arrow-'+id);c.style.display='block';a.textContent='▾';c.scrollIntoView({behavior:'smooth',block:'nearest'})})('{{ block.id }}')">Términos y Condiciones</span> del programa de suscripción.</span>
          </label>
        </div>

        <button id="m-btn-{{ block.id }}" style="width:100%;background:#9d2a23;color:#fff;border:none;border-radius:8px;padding:15px;font-size:14px;font-weight:800;cursor:pointer;letter-spacing:.3px">
          Continuar al pago →
        </button>
        <div style="text-align:center;font-size:11px;color:#999;margin-top:10px">
          Serás redirigido a Mercado Pago para autorizar tu suscripción.
        </div>
      </div>
    </div>
  </div>
  {% endunless %}

</div>

<script>
(function() {
  var blkId = '{{ block.id }}';
  var wrap = document.getElementById('lab-sub-' + blkId);
  var hasNativePlans = {{ has_plans | json }};  wrap.querySelectorAll('.lab-sub__tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      wrap.querySelectorAll('.lab-sub__tab').forEach(function(t) { t.classList.remove('lab-sub__tab--active'); });
      wrap.querySelectorAll('.lab-sub__panel').forEach(function(p) { p.classList.remove('lab-sub__panel--active'); });
      tab.classList.add('lab-sub__tab--active');
      var panel = wrap.querySelector('[data-panel="' + tab.dataset.tab + '"]');
      if (panel) panel.classList.add('lab-sub__panel--active');
    });
  });  function labCartUpdate() {
    // 1. Leer carrito actualizado
    fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
      var count = cart.item_count;
      // 2. Actualizar TODOS los posibles selectores del contador
      var selectors = [
        '.cart-bubble__text span',         // Lab Nutrition / Cluster theme
        '.cart-count-bubble span',         // Dawn theme
        '[data-cart-count]',               // Generic
        '.cart-count',                     // Generic
        '#cart-icon-bubble span',          // Some themes
        '.header__cart-count'              // Other themes
      ];
      selectors.forEach(function(sel) {
        document.querySelectorAll(sel).forEach(function(el) { el.textContent = count; });
      });
      // 3. Mostrar la burbuja del carrito si estaba oculta
      document.querySelectorAll('.cart-bubble, .cart-count-bubble').forEach(function(el) {
        el.style.display = '';
        el.removeAttribute('hidden');
      });
    }).catch(function() {});

    // 4. Refrescar el cart-drawer via Section Rendering API (instantáneo)
    var drawerSection = document.querySelector('cart-drawer');
    if (drawerSection) {
      var sectionId = drawerSection.closest('[id^="shopify-section"]');
      if (sectionId) {
        var secName = sectionId.id.replace('shopify-section-', '');
        fetch('/?sections=' + secName).then(function(r) { return r.json(); }).then(function(sections) {
          if (sections[secName]) {
            var tmp = document.createElement('div');
            tmp.innerHTML = sections[secName];
            var newDrawer = tmp.querySelector('cart-drawer') || tmp.querySelector('.cart-drawer');
            if (newDrawer && drawerSection) {
              drawerSection.innerHTML = newDrawer.innerHTML;
            }
          }
        }).catch(function() {});
      }
      // Intentar abrir el drawer
      try {
        if (typeof drawerSection.open === 'function') drawerSection.open();
        else if (drawerSection.querySelector('details')) drawerSection.querySelector('details').setAttribute('open', '');
        else drawerSection.classList.add('is-open', 'active');
      } catch(e) {}
    }
    // 5. Disparar eventos personalizados para que el tema reaccione
    document.dispatchEvent(new CustomEvent('cart:refresh'));
    document.dispatchEvent(new CustomEvent('cart:updated'));
  }  window.labSubAddOnce = function(id) {
    if (id !== blkId) return;
    var variantId = parseInt(wrap.dataset.variant);
    if (!variantId) return;
    var btn = document.getElementById('once-cta-' + id);
    if (btn) { btn.disabled = true; btn.querySelector('.lab-sub__cta-text').textContent = 'Añadiendo...'; }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.id) {
        if (btn) { btn.querySelector('.lab-sub__cta-text').textContent = 'Añadido al carrito'; btn.style.background = '#2E7D49'; }
        labCartUpdate();
        setTimeout(function() {
          if (btn) { btn.disabled = false; btn.querySelector('.lab-sub__cta-text').textContent = 'Agregar al carrito'; btn.style.background = ''; }
        }, 2500);
      } else { throw new Error(data.description || 'Error'); }
    })
    .catch(function() {
      if (btn) { btn.disabled = false; btn.querySelector('.lab-sub__cta-text').textContent = 'Agregar al carrito'; }
    });
  };  window.labSubOpenModal = function(id) {
    if (id !== blkId) return;
    var modal = document.getElementById('lab-modal-' + id);
    if (modal) modal.style.display = 'flex';
  };  var productHandle = '{{ product.handle }}';

  // 🔒 Variant allowlist (hardcoded baseline + admin setting). Fail-safe: si no hay config, tab Suscripción se oculta.
  var HARDCODED_ELIGIBLE = ['58307532587089'];
  var eligibleRaw = '{{ block.settings.eligible_variant_ids | default: "" }}';
  var eligibleVariants = HARDCODED_ELIGIBLE.slice();
  (eligibleRaw ? eligibleRaw.split(',') : []).forEach(function(s){ s = (s||'').trim(); if (s && eligibleVariants.indexOf(s)===-1) eligibleVariants.push(s); });
  var noticeEl = document.getElementById('variant-notice-' + blkId);
  var subContentEl = document.getElementById('sub-content-' + blkId);
  var subTabBtn = wrap.querySelector('.lab-sub__tab[data-tab="sub"]');
  var onceTabBtn = wrap.querySelector('.lab-sub__tab[data-tab="once"]');
  var subPanel = wrap.querySelector('.lab-sub__panel[data-panel="sub"]');
  var oncePanel = wrap.querySelector('.lab-sub__panel[data-panel="once"]');
  function checkVariantEligibility(variantId) {
    var ok = eligibleVariants.length > 0 && eligibleVariants.indexOf(String(variantId)) !== -1;
    if (noticeEl) noticeEl.style.display = ok ? 'none' : 'block';
    if (subContentEl) subContentEl.style.display = ok ? '' : 'none';
    if (subTabBtn) { subTabBtn.style.display = ok ? '' : 'none'; subTabBtn.disabled = !ok; subTabBtn.setAttribute('aria-disabled', String(!ok)); }
    if (!ok && subTabBtn && subTabBtn.classList.contains('lab-sub__tab--active')) {
      subTabBtn.classList.remove('lab-sub__tab--active');
      if (subPanel) subPanel.classList.remove('lab-sub__panel--active');
      if (onceTabBtn) onceTabBtn.classList.add('lab-sub__tab--active');
      if (oncePanel) oncePanel.classList.add('lab-sub__panel--active');
    }
  }
  checkVariantEligibility(wrap.dataset.variant);

  function updateForVariant(v) {
    if (!v || !v.id) return;
    var price = v.price;
    var compare = v.compare_at_price;
    var saleF = (price / 100).toFixed(2);
    var compF = compare ? (compare / 100).toFixed(2) : null;
    var cur = wrap.dataset.currency || 'PEN';
    wrap.dataset.variant = v.id;
    wrap.dataset.price = saleF;
    var priceEl = wrap.querySelector('.lab-sub__price-num');
    var compEl = wrap.querySelector('.lab-sub__price-compare');
    var pctEl = wrap.querySelector('.lab-sub__price-pct');
    if (priceEl) priceEl.textContent = cur + ' ' + saleF;
    if (compare && compare > price) {
      var pct = Math.round((compare - price) * 100 / compare);
      if (compEl) { compEl.textContent = cur + ' ' + compF; compEl.style.display = ''; }
      if (pctEl) { pctEl.textContent = '-' + pct + '%'; pctEl.style.display = ''; }
    } else {
      if (compEl) compEl.style.display = 'none';
      if (pctEl) pctEl.style.display = 'none';
    }
    // Check variant eligibility for subscriptions
    checkVariantEligibility(v.id);
  }

  function fetchVariant(variantId) {
    if (!variantId) return;
    fetch('/products/' + productHandle + '/variants/' + variantId + '.json')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(d) { if (d && d.variant) updateForVariant(d.variant); })
      .catch(function() {});
  }

  document.addEventListener('variant:changed', function(e) {
    var v = e.detail && (e.detail.variant || e.detail);
    if (v && v.id) updateForVariant(v);
  });

  var productForm = document.querySelector('form[action="/cart/add"]');
  if (productForm) {
    productForm.addEventListener('change', function() {
      var h = productForm.querySelector('input[name="id"]');
      if (h && h.value) fetchVariant(h.value);
    });
  }

  var urlParams = new URLSearchParams(window.location.search);
  var urlVariant = urlParams.get('variant');
  if (urlVariant && urlVariant !== wrap.dataset.variant) fetchVariant(urlVariant);  var socialEl = document.getElementById('social-text-' + blkId);
  if (socialEl) {
    var backend = wrap.dataset.backend || 'https://pixel-suite-pro-production.up.railway.app';
    fetch(backend + '/api/metrics')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(d) {
        if (d && d.active > 0) socialEl.textContent = d.active + ' suscriptores activos';
        else socialEl.parentElement.style.display = 'none';
      })
      .catch(function() { if (socialEl && socialEl.parentElement) socialEl.parentElement.style.display = 'none'; });
  }  if (!hasNativePlans) {
    var config = {};
    var activePlans = []; // planes asignados y habilitados para este producto
    var selectedPlanKey = null;

    function buildChipsFromPlans(plans) {
      // Render dynamic chips from saved plan config
      var subPanel = wrap.querySelector('[data-panel="sub"]');
      if (!subPanel) return;

      // Group unique frequencies and permanences from enabled plans
      var enabledPlans = plans.filter(function(p) { return p.enabled !== false; });
      if (!enabledPlans.length) { subPanel.innerHTML = '<div style="text-align:center;padding:20px;color:#888;font-size:13px">No hay planes configurados para este producto.</div>'; return; }

      // New approach: show one chip per plan directly (frequency + permanence = 1 plan)
      var chipsHtml = '<div class="lab-sub__group"><p class="lab-sub__label">Elige tu plan</p><div class="lab-sub__chips" id="plan-chips-' + blkId + '">';
      enabledPlans.forEach(function(plan, i) {
        var key = plan.key;
        var label = plan.label || ((plan.frequency === 1 ? 'Mensual' : 'Cada ' + plan.frequency + 'm') + ' · ' + plan.permanence + ' meses');
        // Badge si este plan trae regalo para este producto (sin emoji — renderiza inconsistente a 10px)
        var hasGift = plan.gifts && plan.gifts.enabled && plan.gifts.summary && plan.gifts.summary.length > 0;
        var giftBadge = hasGift ? '<span style="display:inline-block;margin-left:6px;background:var(--lab-gift-badge-bg,#E30613);color:var(--lab-gift-badge-text,#fff);font-size:10px;font-weight:800;padding:3px 8px;border-radius:12px;letter-spacing:.5px;vertical-align:middle;line-height:1.3;white-space:nowrap;flex-shrink:0">REGALO</span>' : '';
        chipsHtml += '<button class="lab-sub__chip' + (i === 0 ? ' lab-sub__chip--active' : '') + '" data-plan-key="' + key + '">' + label + giftBadge + '</button>';
      });
      chipsHtml += '</div></div>';

      // Benefit box
      {% if block.settings.show_benefit_box %}
      chipsHtml += '<div class="lab-sub__benefit" id="benefit-' + blkId + '">' +
        '<div class="lab-sub__benefit-top">' +
        '<div class="lab-sub__pct" id="pct-' + blkId + '">–% OFF</div>' +
        '<div class="lab-sub__prices"><span class="lab-sub__was" id="was-' + blkId + '"></span><span class="lab-sub__now" id="now-' + blkId + '"></span></div>' +
        '</div><div class="lab-sub__saving" id="saving-' + blkId + '"></div></div>';
      {% endif %}

      // Gift box (si el plan seleccionado trae regalo). Escondido por default; renderSelectedPlan lo llena.
      // Soporta 1 o N regalos. Cada item es clickeable si tiene product_handle.
      chipsHtml += '<div id="gift-' + blkId + '" style="display:none;margin:10px 0;padding:30px 14px 12px 14px;background:linear-gradient(135deg,var(--lab-gift-bg-from,#fff8e1),var(--lab-gift-bg-to,#fff1c7));border:1.5px solid var(--lab-gift-border,#f2c94c);border-radius:10px;position:relative">' +
        '<div style="position:absolute;top:0;right:0;background:var(--lab-gift-badge-bg,#E30613);color:var(--lab-gift-badge-text,#fff);font-size:10px;font-weight:900;padding:4px 10px;border-radius:0 8px 0 8px;letter-spacing:1px;z-index:2;line-height:1.2;white-space:nowrap">REGALO</div>' +
        '<div style="font-size:11px;font-weight:800;color:var(--lab-gift-label,#8B6914);letter-spacing:.8px;text-transform:uppercase;margin-bottom:8px">Tu primer envío incluye</div>' +
        '<div id="gift-items-' + blkId + '" style="display:flex;flex-direction:column;gap:8px"></div>' +
        '</div>';

      // Perks
      {% if block.settings.show_perks %}
      chipsHtml += '<div class="lab-sub__perks">' +
        {% if block.settings.perk_1 != blank %} '<div class="lab-sub__perk">{{ block.settings.perk_1 | escape }}</div>' + {% endif %}
        {% if block.settings.perk_2 != blank %} '<div class="lab-sub__perk">{{ block.settings.perk_2 | escape }}</div>' + {% endif %}
        {% if block.settings.perk_3 != blank %} '<div class="lab-sub__perk">{{ block.settings.perk_3 | escape }}</div>' + {% endif %}
        {% if block.settings.perk_4 != blank %} '<div class="lab-sub__perk">{{ block.settings.perk_4 | escape }}</div>' + {% endif %}
        '</div>';
      {% endif %}

      // Legal
      {% if block.settings.show_legal %}
      chipsHtml += '<div class="lab-sub__legal">{{ legal_txt | escape }}</div>';
      {% endif %}

      // CTA
      chipsHtml += '<button class="lab-sub__cta" id="cta-' + blkId + '" onclick="labSubOpenModal(\'' + blkId + '\')">' +
        '<span class="lab-sub__cta-text" id="cta-txt-' + blkId + '">Suscribirme →</span></button>';

      subPanel.innerHTML = chipsHtml;

      // Select first plan by default
      if (enabledPlans.length) {
        selectedPlanKey = enabledPlans[0].key;
        renderSelectedPlan(enabledPlans[0]);
      }

      // Attach chip click events
      wrap.querySelectorAll('.lab-sub__chip[data-plan-key]').forEach(function(chip) {
        chip.addEventListener('click', function() {
          wrap.querySelectorAll('.lab-sub__chip[data-plan-key]').forEach(function(c) { c.classList.remove('lab-sub__chip--active'); });
          chip.classList.add('lab-sub__chip--active');
          selectedPlanKey = chip.dataset.planKey;
          var plan = enabledPlans.find(function(p) { return p.key === selectedPlanKey; });
          if (plan) renderSelectedPlan(plan);
        });
      });
    }

    function renderSelectedPlan(plan) {
      if (!plan) return;
      var base = parseFloat(wrap.dataset.price || 0);
      var cur = wrap.dataset.curSymbol || wrap.dataset.currency || 'PEN';
      var forceP = plan.forcePrice;
      var rawDisc, finalPrice;
      if (plan.hasForce) {
        finalPrice = forceP;
        rawDisc = ((base - finalPrice) / base) * 100;
      } else {
        var apiDisc = plan.discount || 0;
        rawDisc = apiDisc;
        finalPrice = base * (1 - rawDisc / 100);
      }
      var saving = (base - finalPrice).toFixed(2);
      var displayDisc = Math.round(rawDisc);
      var pctEl = document.getElementById('pct-' + blkId);
      var nowEl = document.getElementById('now-' + blkId);
      var wasEl = document.getElementById('was-' + blkId);
      var savEl = document.getElementById('saving-' + blkId);
      var ctaTxt = document.getElementById('cta-txt-' + blkId);
      if (pctEl) pctEl.textContent = displayDisc + '% OFF';
      if (nowEl) nowEl.textContent = cur + ' ' + finalPrice.toFixed(2);
      if (wasEl) wasEl.textContent = rawDisc > 0 ? cur + ' ' + base.toFixed(2) : '';
      if (savEl) savEl.textContent = rawDisc > 0 ? 'Ahorras ' + cur + ' ' + saving + ' cada mes (1 unidad)' : '';
      if (ctaTxt) ctaTxt.textContent = 'Suscribirme — ' + displayDisc + '% OFF →';

      // Render gift box si el plan trae regalos. Soporta 1 o N items, cada uno clickeable si tiene handle.
      var giftBox = document.getElementById('gift-' + blkId);
      var giftItems = document.getElementById('gift-items-' + blkId);
      if (giftBox && giftItems && plan && plan.gifts && plan.gifts.enabled && plan.gifts.summary && plan.gifts.summary.length) {
        var items = plan.gifts.summary;
        var itemsHtml = items.map(function(it) {
          var q = it.quantity > 1 ? (it.quantity + 'x ') : '';
          var vt = it.variant_title && it.variant_title !== 'Default Title' ? ' (' + it.variant_title + ')' : '';
          var title = q + (it.title || 'Regalo') + vt;
          var hasLink = !!it.product_handle;
          var imgHtml = it.image
            ? '<img src="' + it.image + '" alt="" style="width:100%;height:100%;object-fit:cover">'
            : '<span style="font-size:9px;font-weight:800;color:var(--lab-gift-badge-bg,#E30613);letter-spacing:.5px">GIFT</span>';
          var titleStyle = 'font-size:13px;font-weight:700;color:var(--lab-gift-title,#4A3100);line-height:1.3;overflow:hidden;text-overflow:ellipsis' + (hasLink ? ';text-decoration:underline;text-decoration-color:rgba(74,49,0,.3);text-underline-offset:3px' : '');
          var hintHtml = hasLink ? '<div style="font-size:10px;color:var(--lab-gift-label,#8B6914);margin-top:2px;font-weight:600">Ver producto →</div>' : '';
          var wrapStart, wrapEnd;
          if (hasLink) {
            wrapStart = '<a href="/products/' + it.product_handle + '" target="_blank" rel="noopener" style="display:flex;gap:10px;align-items:center;text-decoration:none;color:inherit;cursor:pointer">';
            wrapEnd = '</a>';
          } else {
            wrapStart = '<div style="display:flex;gap:10px;align-items:center">';
            wrapEnd = '</div>';
          }
          return wrapStart +
            '<div style="width:44px;height:44px;border-radius:8px;background:#fff;flex-shrink:0;border:1px solid #e8d88c;overflow:hidden;display:flex;align-items:center;justify-content:center">' + imgHtml + '</div>' +
            '<div style="flex:1;min-width:0">' +
            '<div style="' + titleStyle + '">' + title + '</div>' +
            hintHtml +
            '</div>' +
            wrapEnd;
        }).join('');
        giftItems.innerHTML = itemsHtml;
        giftBox.style.display = 'block';
      } else if (giftBox) {
        giftBox.style.display = 'none';
      }
    }

    function loadConfig() {
      var productId = wrap.dataset.product;
      var backendUrl = wrap.dataset.backend;
      if (!productId || !backendUrl) return;
      fetch(backendUrl + '/api/products/' + productId + '/config')
        .then(function(r) { return r.ok ? r.json() : {}; })
        .then(function(cfg) {
          config = cfg || {};
          // Auto-sync variants desde backend: si el admin configuró variantes elegibles
          //    para este producto, se agregan al allowlist local y se re-chequea la variante actual.
          //    Esto evita tener que actualizar manualmente `eligible_variant_ids` en el tema
          //    cada vez que se activa la suscripción en un nuevo producto. (Aditivo — nunca remueve).
          if (cfg && Array.isArray(cfg.eligible_variant_ids) && cfg.eligible_variant_ids.length) {
            cfg.eligible_variant_ids.forEach(function(v) {
              v = String(v || '').trim();
              if (v && eligibleVariants.indexOf(v) === -1) eligibleVariants.push(v);
            });
            checkVariantEligibility(wrap.dataset.variant);
          }
          // New format: config.plans = { planKey: { enabled, discount, frequency, permanence, label } }
          if (cfg && cfg.plans && Object.keys(cfg.plans).length) {
            activePlans = Object.keys(cfg.plans)
              .filter(function(k) { return cfg.plans[k].enabled !== false; })
              .map(function(k) {
                return Object.assign({ key: k }, cfg.plans[k]);
              })
              .sort(function(a, b) { return (a.frequency - b.frequency) || (a.permanence - b.permanence); });
          } else if (cfg && cfg.discounts) {
            // Legacy format fallback
            activePlans = [
              { key: 'm1_p3', label: 'Mensual · 3 meses', frequency: 1, permanence: 3, discount: cfg.discounts.m1_p3 || 10, enabled: true },
              { key: 'm1_p6', label: 'Mensual · 6 meses', frequency: 1, permanence: 6, discount: cfg.discounts.m1_p6 || 15, enabled: true },
              { key: 'm1_p12', label: 'Mensual · 12 meses', frequency: 1, permanence: 12, discount: cfg.discounts.m1_p12 || 25, enabled: true },
              { key: 'm2_p3', label: 'Bimestral · 3 meses', frequency: 2, permanence: 3, discount: cfg.discounts.m2_p3 || 12, enabled: true },
              { key: 'm2_p6', label: 'Bimestral · 6 meses', frequency: 2, permanence: 6, discount: cfg.discounts.m2_p6 || 18, enabled: true },
              { key: 'm2_p12', label: 'Bimestral · 12 meses', frequency: 2, permanence: 12, discount: cfg.discounts.m2_p12 || 30, enabled: true },
            ];
          }
          if (activePlans.length) {
            var overrides = [wrap.dataset.p1, wrap.dataset.p2, wrap.dataset.p3, wrap.dataset.p4];
            activePlans.forEach(function(p, i) {
              var o = overrides[i];
              if (o) {
                p.forcePrice = parseFloat(o.replace(',', '.'));
                p.hasForce = !isNaN(p.forcePrice);
              }
            });
            buildChipsFromPlans(activePlans);
          }
        })
        .catch(function() {});
    }    window.labSubOpenModal = function(id) {
      if (id !== blkId) return;
      var modal = document.getElementById('lab-modal-' + id);
      if (modal) modal.style.display = 'flex';
      // Pre-fill modal with selected plan info
      var plan = selectedPlanKey && activePlans.find(function(p) { return p.key === selectedPlanKey; });
      if (plan) {
        var title = document.getElementById('modal-title-' + id);
        var priceEl = document.getElementById('modal-price-' + id);
        var discEl = document.getElementById('modal-disc-' + id);
        var savingEl = document.getElementById('modal-saving-' + id);
        var base = parseFloat(wrap.dataset.price || 0);
        var cur = wrap.dataset.curSymbol || wrap.dataset.currency || 'PEN';
        var rawDisc, finalPrice;
        if (plan && plan.hasForce) {
          finalPrice = plan.forcePrice;
          rawDisc = ((base - finalPrice) / base) * 100;
        } else {
          var apiD = plan ? plan.discount : 0;
          rawDisc = apiD;
          finalPrice = base * (1 - rawDisc / 100);
        }
        var displayDisc = Math.round(rawDisc);
        var finalP_fmt = finalPrice.toFixed(2);
        if (title) title.textContent = plan.label || 'Suscripción';
        if (priceEl) priceEl.textContent = cur + ' ' + finalP_fmt;
        if (discEl) discEl.textContent = displayDisc + '% OFF';
        if (savingEl) savingEl.textContent = 'Ahorras ' + cur + ' ' + (base - finalPrice).toFixed(2);
      }
    };

    // Modal submit → Save address + Create MP checkout → Redirect to MP
    var mBtn = document.getElementById('m-btn-' + blkId);
    if (mBtn) {
      mBtn.addEventListener('click', function() {
        var name = (document.getElementById('m-name-' + blkId) || {}).value;
        var email = (document.getElementById('m-email-' + blkId) || {}).value;
        var phone = (document.getElementById('m-phone-' + blkId) || {}).value || '';
        var tipodoc = (document.getElementById('m-tipodoc-' + blkId) || {}).value || '01';
        var dni = (document.getElementById('m-dni-' + blkId) || {}).value || '';
        var addr1 = (document.getElementById('m-addr-' + blkId) || {}).value;
        var city = (document.getElementById('m-city-' + blkId) || {}).value;
        var province = (document.getElementById('m-province-' + blkId) || {}).value || 'Lima';
        var tcCheck = document.getElementById('lab-tc-check-' + blkId);
        if (!name || !email || !email.includes('@') || !addr1 || !city || !dni) {
          var msgEl = document.getElementById('m-msg-' + blkId);
          if (msgEl) { msgEl.style.display = 'block'; msgEl.style.background = '#fee2e2'; msgEl.style.color = '#991b1b'; msgEl.textContent = 'Completa nombre, email, documento, dirección y distrito.'; }
          return;
        }
        if (tcCheck && !tcCheck.checked) {
          var msgEl = document.getElementById('m-msg-' + blkId);
          if (msgEl) { msgEl.style.display = 'block'; msgEl.style.background = '#fee2e2'; msgEl.style.color = '#991b1b'; msgEl.textContent = 'Debes aceptar los Términos y Condiciones para continuar.'; }
          return;
        }
        var plan = selectedPlanKey && activePlans.find(function(p) { return p.key === selectedPlanKey; });
        var currentFreq = plan ? plan.frequency : 1;
        var currentPerm = plan ? plan.permanence : 3;
        var base = parseFloat(wrap.dataset.price || 0);
        var rawDisc, finalPrice;
        if (plan && plan.hasForce) {
          finalPrice = plan.forcePrice;
          rawDisc = ((base - finalPrice) / base) * 100;
        } else {
          var apiDisc = plan ? plan.discount : 10;
          rawDisc = apiDisc;
          finalPrice = base * (1 - rawDisc / 100);
        }
        var finalPriceNum = parseFloat(finalPrice.toFixed(2));
        var discNum = parseFloat(rawDisc.toFixed(2));
        var backendUrl = wrap.dataset.backend || 'https://pixel-suite-pro-production.up.railway.app';
        mBtn.disabled = true; mBtn.textContent = 'Procesando...';

        // Build shipping address
        var nameParts = name.trim().split(' ');
        var PE_PROV = {'lima':'LIM','arequipa':'ARE','cusco':'CUS','la libertad':'LAL','piura':'PIU','lambayeque':'LAM','junin':'JUN','cajamarca':'CAJ','ancash':'ANC','ica':'ICA','callao':'CAL','tacna':'TAC','loreto':'LOR','san martin':'SAM','ucayali':'UCA','huanuco':'HUA','puno':'PUN','amazonas':'AMA','ayacucho':'AYA','apurimac':'APU','huancavelica':'HUV','madre de dios':'MDD','moquegua':'MOQ','pasco':'PAS','tumbes':'TUM'};
        var shippingAddress = {
          first_name: nameParts[0] || name,
          last_name: nameParts.slice(1).join(' ') || '',
          address1: addr1,
          city: city,
          province: province,
          province_code: PE_PROV[(province || '').toLowerCase()] || 'LIM',
          country: 'PE',
          country_code: 'PE',
          zip: '15000',
          phone: phone
        };

        // Create MP checkout via backend (saves subscription + returns MP init_point)
        fetch(backendUrl + '/api/subscriptions/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            customer_name: name,
            customer_email: email,
            customer_phone: phone,
            tipo_documento: tipodoc,
            dni: dni,
            product_id: wrap.dataset.product,
            variant_id: wrap.dataset.variant,
            product_title: wrap.dataset.title,
            base_price: base,
            final_price: finalPriceNum,
            discount_pct: discNum,
            frequency_months: currentFreq,
            permanence_months: currentPerm,
            free_shipping: false,
            shipping_address: shippingAddress,
            tc_accepted: true,
            tc_version: '1.0',
            tc_accepted_at: new Date().toISOString()
          })
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.init_point || d.url) {
            mBtn.textContent = 'Redirigiendo a Mercado Pago...';
            mBtn.style.background = '#2E7D49';
            setTimeout(function() { window.location.href = d.init_point || d.url; }, 500);
          } else {
            throw new Error(d.error || 'No se pudo crear el checkout');
          }
        })
        .catch(function(err) {
          var msgEl = document.getElementById('m-msg-' + blkId);
          if (msgEl) { msgEl.style.display = 'block'; msgEl.style.background = '#fee2e2'; msgEl.style.color = '#991b1b'; msgEl.textContent = err.message; }
          mBtn.disabled = false; mBtn.textContent = 'Continuar al pago →';
        });
      });
    }

    loadConfig(); // Load and render plans for this product
  }
})();

</script>

