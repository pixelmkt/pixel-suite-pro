# LAB NUTRITION Backend — Environment Variables
# Copy this to .env and fill in your values

# ── SERVER ─────────────────────────────
PORT=3000
NODE_ENV=production
BACKEND_URL=https://your-app.railway.app  # update after deploy

# ── SHOPIFY ────────────────────────────────────────────
SHOPIFY_SHOP=nutrition-lab-cluster.myshopify.com
SHOPIFY_ACCESS_TOKEN=                     # Admin API token (read/write orders)
SHOPIFY_WEBHOOK_SECRET=                   # Shopify webhook HMAC secret
SHOPIFY_API_VERSION=2025-01

# ── MERCADO PAGO ────────────────────────────────────────
MP_ACCESS_TOKEN=                          # Your MP production access token
MP_PUBLIC_KEY=                            # Your MP public key
MP_WEBHOOK_SECRET=                        # MP webhook secret (signature)

# ── SUPABASE ───────────────────────────────────────────
SUPABASE_URL=                             # https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=                     # Service role key (server only)

# ── NOTIFICATIONS ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                                # notifications@labnutrition.com
SMTP_PASS=                                # App password
EMAIL_FROM="LAB NUTRITION <notificaciones@labnutrition.com>"
WHATSAPP_API_URL=                         # Optional: WA Business API
